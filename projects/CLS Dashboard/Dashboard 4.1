def render_study_criteria(sdf: pd.DataFrame):
    chips = []
    for f in CRITERIA_FIELDS:
        if f in sdf.columns:
            vals = sdf[f].dropna().astype(str).unique().tolist()
            if vals:
                v = ", ".join(sorted(set(vals))[:4])
                chips.append(f"<span class='chip'><b>{f}</b>: {v}</span>")
    st.markdown("".join(chips), unsafe_allow_html=True)


with tab_studies:
    if "Study Name" not in fdf.columns:
        st.info("No Study Name column.")
    else:
        agg_dict = {}
        for c in (
            "Control Conversions Scaled",
            "Treatment Conversions",
            "Test Cell Size",
            "Control Cell Size",
        ):
            if c in fdf.columns:
                agg_dict[c] = "sum"
        for c in ("Test CVR", "Control CVR", "p_value"):
            if c in fdf.columns:
                agg_dict[c] = "mean"
        if agg_dict:
            tbl = fdf.groupby("Study Name", as_index=False).agg(agg_dict)
            if {"Test CVR", "Control CVR"}.issubset(tbl.columns):
                tbl["Lift %"] = (
                    (tbl["Test CVR"] - tbl["Control CVR"])
                    / tbl["Control CVR"].replace(0, np.nan)
                ) * 100
            if "p_value" in tbl.columns:
                tbl["Confidence"] = (1 - tbl["p_value"]) * 100
            st.dataframe(tbl, use_container_width=True, hide_index=True)

        st.markdown("---")
        st.markdown("#### Study Criteria")
        for study, sdf in fdf.groupby("Study Name"):
            st.markdown(f"**{study}**")
            render_study_criteria(sdf)
