    # Spend / volume
    "measured spend": "Total Spend",
    "incremental conversions": "Incremental Conversions",
}

REGION_MAP = {
    "US": "NA", "CA": "NA",
    "GB": "EMEA", "DE": "EMEA", "FR": "EMEA", "ES": "EMEA",
    "IT": "EMEA", "NL": "EMEA", "SE": "EMEA", "AE": "EMEA",
    "AU": "APAC", "NZ": "APAC", "JP": "APAC", "KR": "APAC",
    "SG": "APAC", "HK": "APAC", "TW": "APAC", "ID": "APAC",
    "BR": "LATAM", "MX": "LATAM", "AR": "LATAM", "CL": "LATAM",
}


def normalize_columns(df: pd.DataFrame) -> pd.DataFrame:
    if df.empty:
        return df

    cleaned, drop_idx = dedupe_columns(list(df.columns))
    if drop_idx:
        df = df.drop(df.columns[drop_idx], axis=1)
        cleaned = [n for i, n in enumerate(cleaned) if i not in set(drop_idx)]
    df.columns = cleaned

    new_cols = {c: COLUMN_ALIASES.get(str(c).strip().lower(), c) for c in df.columns}
    df = df.rename(columns=new_cols)

    cleaned2, _ = dedupe_columns(list(df.columns))
    df.columns = cleaned2

    for dc in ("Study Start Date", "Study End Date"):
        if dc in df.columns:
            df[dc] = parse_date_col(df[dc])
    if "p_date" in df.columns:
        df["p_date"] = parse_date_col(df["p_date"], yyyymmdd=True)

    for nc in (
        "Control Conversions Scaled",
        "Treatment Conversions",
        "Test Cell Size",
        "Control Cell Size",
        "Test CVR",
        "Control CVR",
        "p_value",
        "Total Spend",
        "Incremental Conversions",
        "Reach",
        "Holdout Rate",
        "Conversion Relative Lift",
        "Conversion Relative Lift Lower",
        "Conversion Relative Lift Upper",
    ):
        if nc in df.columns:
            df[nc] = df[nc].apply(_to_num)

    if "Region" not in df.columns and "Country" in df.columns:
        df["Region"] = df["Country"].astype(str).str.upper().map(REGION_MAP).fillna("Other")

    return df


