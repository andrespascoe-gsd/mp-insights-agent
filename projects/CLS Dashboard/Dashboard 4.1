# ----------------------------- Hero metrics -----------------------------
def compute_hero(_df: pd.DataFrame, preferred_event: str = "start_trial") -> dict:
    out = {"studies": 0, "sig": 0, "lift_avg": np.nan, "p_med": np.nan}
    if _df.empty or "Study Name" not in _df.columns:
        return out
    base = _df.copy()
    if "Measured Event" in base.columns:
        m = base["Measured Event"].astype(str).str.strip().str.lower() == preferred_event
        if m.any():
            base = base[m]
    out["studies"] = base["Study Name"].nunique()
    if "p_value" in base.columns:
        agg = base.groupby("Study Name")["p_value"].min()
        out["sig"] = int((agg <= 0.1).sum())
        out["p_med"] = float(agg.median()) if len(agg) else np.nan
    if {"Test CVR", "Control CVR"}.issubset(base.columns):
        lift = (base["Test CVR"] - base["Control CVR"]) / base["Control CVR"].replace(0, np.nan)
        out["lift_avg"] = float(lift.mean()) if lift.notna().any() else np.nan
    return out


