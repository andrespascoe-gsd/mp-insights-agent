    "Reviewed Date", "Reviewed By", "Reporting Quarter", "Fiscal Year",
    "Tags", "Confidential", "Last Updated",
]


def _cost_for_event(
    sdf: pd.DataFrame,
    event_name: str,
    spend_col: str = "Total Spend",
    inc_col: str = "Incremental Conversions",
) -> float:
    if "Measured Event" not in sdf.columns:
        return np.nan
    m = sdf["Measured Event"].astype(str).str.strip().str.lower() == event_name.lower()
    sub = sdf[m]
    if sub.empty or spend_col not in sub.columns or inc_col not in sub.columns:
        return np.nan
    spend = pd.to_numeric(sub[spend_col], errors="coerce").sum()
    inc = pd.to_numeric(sub[inc_col], errors="coerce").sum()
    if not inc or pd.isna(inc) or inc == 0:
        return np.nan
    return float(spend) / float(inc)


with tab_monday:
    st.markdown("#### Monday.com export (42 columns)")
    rows = []
    for study, sdf in fdf.groupby("Study Name"):
        row = {c: "" for c in MONDAY_COLUMNS}
        row["Study Name"] = study
        for f in (
            "Region",
            "Country",
            "Channel",
            "Objective",
            "Ad Type",
            "Measured Event",
        ):
            if f in sdf.columns:
                vals = sdf[f].dropna().astype(str).unique().tolist()
                row[f] = ", ".join(sorted(set(vals)))
        if "Study Start Date" in sdf.columns:
            row["Study Start Date"] = _iso(sdf["Study Start Date"].min()) or ""
        if "Study End Date" in sdf.columns:
            row["Study End Date"] = _iso(sdf["Study End Date"].max())or ""
        for f in ("Test Cell Size", "Control Cell Size"):
            if f in sdf.columns:
                row[f] = pd.to_numeric(sdf[f], errors="coerce").sum()
        for f in ("Test CVR", "Control CVR"):
            if f in sdf.columns:
                row[f] = pd.to_numeric(sdf[f], errors="coerce").mean()
        if (
            isinstance(row["Test CVR"], (int, float))
            and isinstance(row["Control CVR"], (int, float))
            and row["Control CVR"]
        ):
            row["Lift %"] = (
                (row["Test CVR"] - row["Control CVR"]) / row["Control CVR"] * 100
            )
        if "p_value" in sdf.columns:
            pv = pd.to_numeric(sdf["p_value"], errors="coerce").min()
            row["p_value"] = pv
            row["Confidence"] = (1 - pv) * 100 if pd.notna(pv) else ""
            row["Significant"] = "Yes" if pd.notna(pv) and pv <= 0.1 else "No"
        if "Total Spend" in sdf.columns:
            row["Total Spend"] = pd.to_numeric(sdf["Total Spend"], errors="coerce").sum()
        if "Incremental Conversions" in sdf.columns:
            row["Incremental Conversions"] = pd.to_numeric(
                sdf["Incremental Conversions"], errors="coerce"
            ).sum()
        row["Cost per Trial"] = _cost_for_event(sdf, "start_trial")
        row["Cost per Sign-up"] = _cost_for_event(sdf, "on_web_register")
        row["Last Updated"] = datetime.now().strftime("%Y-%m-%d")
        rows.append(row)

    monday_df = pd.DataFrame(rows, columns=MONDAY_COLUMNS)
    st.dataframe(monday_df, use_container_width=True, hide_index=True)

    out = io.BytesIO()
    with pd.ExcelWriter(out, engine="openpyxl") as w:
        monday_df.to_excel(w, index=False, sheet_name="Monday")
    st.download_button(
        "Download Monday Export (.xlsx)",
        out.getvalue(),
        file_name=f"monday_export_{datetime.now():%Y%m%d_%H%M}.xlsx",
        mime="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
    )
