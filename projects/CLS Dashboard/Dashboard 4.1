# ----------------------------- Helpers -----------------------------
def _iso(d):
    if d is None or pd.isna(d):
        return None
    if isinstance(d, (pd.Timestamp, datetime)):
        return d.strftime("%Y-%m-%d")
    if isinstance(d, date):
        return d.strftime("%Y-%m-%d")
    try:
        return pd.to_datetime(d).strftime("%Y-%m-%d")
    except Exception:
        return None


def _parse_mixed(s: pd.Series) -> pd.Series:
    """Parse a series that may contain Excel serial numbers OR ISO strings."""
    EXCEL_EPOCH = pd.Timestamp("1899-12-30")
    num = pd.to_numeric(s, errors="coerce")
    # Plausible Excel serial range (~1902 to ~2118)
    is_serial = num.notna() & num.between(1000, 80000)
    out = pd.Series(pd.NaT, index=s.index, dtype="datetime64[ns]")
    if is_serial.any():
        out.loc[is_serial] = EXCEL_EPOCH + pd.to_timedelta(
            num[is_serial].astype(float), unit="D"
        )
    rest_mask = out.isna() & s.notna()
    if rest_mask.any():
        parsed = pd.to_datetime(s[rest_mask].astype(str), errors="coerce")
        # Reject the 1970-01-01 sentinel — that's epoch garbage, not a real date
        parsed = parsed.where(parsed != pd.Timestamp("1970-01-01"))
        out.loc[rest_mask] = parsed
    return out


def parse_date_col(series, yyyymmdd=False):
    """
    Robust date parsing.
    - Excel/Lark serials (days since 1899-12-30) → real dates
    - ISO/locale strings → real dates
    - 0, '', None, '0', '—' → NaT (NOT 1970-01-01)
    """
    s = series.copy()

    def _blank_to_nan(x):
        if x is None:
            return np.nan
        if isinstance(x, (int, float, np.integer, np.floating)):
            if pd.isna(x) or float(x) == 0.0:
                return np.nan
            return x
        sx = str(x).strip()
        if sx in {"", "0", "0.0", "—", "-", "N/A", "n/a", "None", "null", "NaN"}:
            return np.nan
        return sx

    s = s.map(_blank_to_nan)

    if yyyymmdd:
        digits = s.astype(str).str.replace(r"\D", "", regex=True)
        mask8 = digits.str.len() == 8
        out = pd.Series(pd.NaT, index=s.index, dtype="datetime64[ns]")
        if mask8.any():
            out.loc[mask8] = pd.to_datetime(
                digits[mask8], format="%Y%m%d", errors="coerce"
            )
        remaining = ~mask8 & s.notna()
        if remaining.any():
            out.loc[remaining] = _parse_mixed(s[remaining])
        return out

    return _parse_mixed(s)


def _to_num(x):
    if pd.isna(x):
        return np.nan
    if isinstance(x, (int, float, np.integer, np.floating)):
        return float(x)
    s = str(x).strip()
    if s in {"", "—", "-", "N/A", "n/a", "NaN"}:
        return np.nan
    s = s.replace(",", "").replace("$", "").replace("%", "")
    try:
        return float(s)
    except Exception:
        return np.nan


def dedupe_columns(cols):
    """Remove blank columns, suffix duplicates as foo, foo__2, foo__3."""
    cleaned = []
    seen = {}
    drop_idx = []
    for i, c in enumerate(cols):
        name = "" if c is None else str(c).strip()
        if name == "":
            drop_idx.append(i)
            cleaned.append(None)
            continue
        if name in seen:
            seen[name] += 1
            cleaned.append(f"{name}__{seen[name]}")
        else:
            seen[name] = 1
            cleaned.append(name)
    return cleaned, drop_idx


# ----------------------------- Lark URL parsing -----------------------------
LARK_BASE = "https://open.larkoffice.com/open-apis"


def parse_lark_sheet_url(url: str):
    if not url:
        return None, None
    url = url.strip()
    m = re.search(r"/(?:sheets|wiki)/([A-Za-z0-9]+)", url)
    token = m.group(1) if m else None
    sheet_id = None
    try:
        parsed = urlparse(url)
        qs = parse_qs(parsed.query)
        if "sheet" in qs and qs["sheet"]:
            sheet_id = qs["sheet"][0]
        else:
            frag = parsed.fragment or ""
            fm = re.search(r"sheet=([A-Za-z0-9]+)", frag)
            if fm:
                sheet_id = fm.group(1)
    except Exception:
        pass
    return token, sheet_id


def resolve_wiki_to_sheet(token: str, wiki_node_token: str) -> str:
    r = requests.get(
        f"{LARK_BASE}/wiki/v2/spaces/get_node",
        params={"token": wiki_node_token, "obj_type": "wiki"},
        headers={"Authorization": f"Bearer {token}"},
        timeout=20,
    )
    r.raise_for_status()
    js = r.json()
    if js.get("code") != 0:
        raise RuntimeError(f"Wiki resolve failed: {js}")
    return js["data"]["node"]["obj_token"]


# ----------------------------- Lark API helpers -----------------------------
@st.cache_data(ttl=3300, show_spinner=False)
def get_lark_token(app_id: str, app_secret: str) -> str:
    r = requests.post(
        f"{LARK_BASE}/auth/v3/tenant_access_token/internal",
        json={"app_id": app_id, "app_secret": app_secret},
        timeout=20,
    )
    r.raise_for_status()
    js = r.json()
    if js.get("code") != 0:
        raise RuntimeError(f"Lark auth failed: {js}")
    return js["tenant_access_token"]


def get_sheet_metadata(token: str, sheet_token: str) -> dict:
    r = requests.get(
        f"{LARK_BASE}/sheets/v3/spreadsheets/{sheet_token}/sheets/query",
        headers={"Authorization": f"Bearer {token}"},
        timeout=20,
    )
    r.raise_for_status()
    return r.json()


def read_range(token, sheet_token, sheet_id, start_row, end_row, end_col_letter="AZ"):
    rng = f"{sheet_id}!A{start_row}:{end_col_letter}{end_row}"
    url = f"{LARK_BASE}/sheets/v2/spreadsheets/{sheet_token}/values/{rng}"
    r = requests.get(url, headers={"Authorization": f"Bearer {token}"}, timeout=60)
    r.raise_for_status()
    js = r.json()
    if js.get("code") != 0:
raise RuntimeError(f"Lark read failed: {js}")
    return js["data"]["valueRange"]["values"] or []


def read_lark_sheet_paginated(token, sheet_token, sheet_id, total_rows, end_col_letter="AZ"):
    rows = []
    header = None
    page_size = 1500
    cursor = 1
    progress = st.progress(0.0, text="Reading Lark sheet…")
    while cursor <= total_rows:
        end = min(cursor + page_size - 1, total_rows)
        try:
            chunk = read_range(token, sheet_token, sheet_id, cursor, end, end_col_letter)
        except Exception as e:
            msg = str(e).lower()
            if ("10mb" in msg or "too large" in msg) and page_size > 100:
                page_size = max(100, page_size // 2)
                continue
            raise
        if not chunk:
            break
        if header is None:
            header = [str(c).strip() if c is not None else "" for c in chunk[0]]
            rows.extend(chunk[1:])
        else:
            rows.extend(chunk)
        cursor = end + 1
        progress.progress(
            min(1.0, cursor / max(1, total_rows)),
            text=f"Reading Lark sheet… {cursor:,}/{total_rows:,}",
        )
    progress.empty()
    if not header:
        return pd.DataFrame()

    width = len(header)
    rows = [r + [None] * (width - len(r)) if len(r) < width else r[:width] for r in rows]

    cleaned, drop_idx = dedupe_columns(header)
    if drop_idx:
        keep = [i for i in range(width) if i not in set(drop_idx)]
        rows = [[r[i] for i in keep] for r in rows]
        cleaned = [cleaned[i] for i in keep]

    return pd.DataFrame(rows, columns=cleaned)


